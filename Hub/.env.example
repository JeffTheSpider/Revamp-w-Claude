# Hub Configuration (optional overrides)
# Copy to .env and customize

# Server port
PORT=3000

# Authentication (optional - leave empty to disable)
# When set, all API requests require Authorization: Bearer <token> or ?token=<token>
# Exception: /api/health is always public, /api/notify uses its own API key
HUB_AUTH_TOKEN=

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
